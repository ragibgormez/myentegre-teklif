.nanbis-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
}

.nanbis-text {
    font-size: 16px;
    color: #fff; /* Yazı rengi */
    transition: opacity 0.3s ease;
    margin-right: 8px; /* Yazı ve logo arasındaki mesafeyi ayarlamak için */
}

.nanbis-logo {
    width: 125px;
    height: 46px;
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0; /* Başlangıçta logo gizli */
    transition: opacity 0.3s ease;
}

.nanbis-link:hover .nanbis-text {
    opacity: 0; /* Yazı kaybolur */
}

.nanbis-link:hover .nanbis-logo {
    opacity: 1; /* Logo görünür hale gelir */
}

